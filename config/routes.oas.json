{
  "openapi": "3.0.0",
  "info": {
    "title": "Global Missile Systems API",
    "description": "A comprehensive API for accessing data on international missile systems, including hypersonic glide vehicles, beyond-visual-range munitions, and tactical defense systems.",
    "version": "1.2.0"
  },
  "servers": [
    {
      "url": "https://your-zuplo-gateway.zuplo.io",
      "description": "Production Environment"
    }
  ],
  "paths": {
    "/missiles": {
      "get": {
        "summary": "List and Filter Missiles",
        "description": "Returns a list of missiles. Use query parameters to narrow down the results based on the manufacturer or the missile's operational type.",
        "operationId": "get-missiles",
        "parameters": [
          {
            "name": "manufacturer",
            "in": "query",
            "description": "The primary contractor or state-owned entity. Example: `Raytheon`, `MBDA`, or `CASIC`.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "The functional category of the missile.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "Air-to-Air",
                "Air-to-Surface",
                "Surface-to-Air",
                "Cruise",
                "Hypersonic Glide Vehicle",
                "Man-portable Anti-tank",
                "Beyond Visual Range Air-to-Air"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A successful retrieval of the missile list.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Missile"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters provided."
          }
        }
      }
    },
    "/missiles/{id}": {
      "get": {
        "summary": "Get Missile by ID",
        "description": "Returns the full details of a single missile record using its unique slug or ID.",
        "operationId": "get-missile-by-id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The unique identifier for the missile (e.g., `aim-260`).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detailed missile information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Missile"
                }
              }
            }
          },
          "404": {
            "description": "Missile not found."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Missile": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique slug-style identifier.",
            "example": "aim-260"
          },
          "name": {
            "type": "string",
            "description": "The official designation and name.",
            "example": "AIM-260 JATM"
          },
          "manufacturer": {
            "type": "string",
            "description": "The company or entity that manufactures the system.",
            "example": "Lockheed Martin"
          },
          "type": {
            "type": "string",
            "description": "The operational classification.",
            "example": "Beyond Visual Range Air-to-Air"
          },
          "range": {
            "type": "string",
            "description": "The effective operational range.",
            "example": "200 km+"
          },
          "speed": {
            "type": "string",
            "description": "The maximum operational speed.",
            "example": "Mach 4+"
          }
        }
      }
    }
  }
}
